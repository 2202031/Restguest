# Backend RestGuest - variables necesarias (copiar a .env o definir en GitHub Secrets)
SPRING_DATASOURCE_URL=jdbc:sqlserver://<servidor>.database.windows.net:1433;database=<basedatos>
SPRING_DATASOURCE_USERNAME=<usuario>
SPRING_DATASOURCE_PASSWORD=<contraseña>
JWT_SECRET=<clave_minimo_32_caracteres>
JWT_EXPIRATION=86400000
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://frontend.vercel.app